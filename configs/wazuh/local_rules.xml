<!--
  Wazuh Custom Detection Rules — local_rules.xml
  Deploy to: /var/ossec/etc/rules/local_rules.xml on the Wazuh manager.
  After editing, restart Wazuh manager: systemctl restart wazuh-manager
  Rule IDs 100000–109999 are reserved for custom local rules.
-->

<group name="sysmon,windows,local">

  <!-- ════════════════════════════════════════════════════════════════════════
       Process Injection — CreateRemoteThread (Sysmon Event ID 8)
       MITRE ATT&CK: T1055
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100010" level="12">
    <if_group>sysmon_event8</if_group>
    <field name="win.eventdata.sourceImage" type="pcre2">(?i)(powershell|cmd|wscript|cscript|mshta|regsvr32|rundll32)\.exe</field>
    <description>Process Injection: CreateRemoteThread from high-risk source process (T1055)</description>
    <mitre>
      <id>T1055</id>
    </mitre>
    <group>process_injection,attack,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════════════════
       Credential Dumping — LSASS Access (Sysmon Event ID 10)
       MITRE ATT&CK: T1003.001
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100020" level="14">
    <if_group>sysmon_event_10</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">0x1fffff|0x1010|0x143a|0x40</field>
    <description>Possible credential dumping: LSASS accessed with suspicious rights (T1003.001)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_access,attack,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════════════════
       Encoded PowerShell Execution (Sysmon Event ID 1)
       MITRE ATT&CK: T1059.001
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100030" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc\s|-encodedcommand\s|-e\s[A-Za-z0-9+/]{20,})</field>
    <description>PowerShell launched with encoded command — possible obfuscation (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>execution,obfuscation,attack,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════════════════
       PowerShell Download Cradle (Sysmon Event ID 1)
       MITRE ATT&CK: T1059.001
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100031" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(downloadstring|iex|invoke-expression|new-object.*webclient)</field>
    <description>PowerShell download cradle detected — possible in-memory payload (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>execution,download_cradle,attack,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════════════════
       Suspicious Outbound Connection from Interpreter (Sysmon Event ID 3)
       MITRE ATT&CK: T1071.001
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100040" level="10">
    <if_group>sysmon_event3</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)(powershell|cmd|python|nc|ncat)\.exe</field>
    <field name="win.eventdata.destinationPort" type="pcre2">^(?!80$|443$|53$|8080$|8443$)\d+$</field>
    <description>Interpreter process connecting outbound on non-standard port — possible C2 (T1071.001)</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>command_and_control,attack,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════════════════
       Persistence — Registry Run Key Modification (Sysmon Event ID 13)
       MITRE ATT&CK: T1547.001
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100050" level="10">
    <if_group>sysmon_event13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(CurrentVersion\\Run|CurrentVersion\\RunOnce)</field>
    <description>Registry Run key modified — possible persistence mechanism (T1547.001)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>persistence,registry,attack,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════════════════
       Scheduled Task Creation (Windows Event ID 4698)
       MITRE ATT&CK: T1053.005
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100060" level="10">
    <if_sid>60010</if_sid>
    <field name="win.system.eventID" type="pcre2">^4698$</field>
    <description>Scheduled task created — possible persistence (T1053.005)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>persistence,scheduled_task,attack,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════════════════
       Multiple Failed Logons (Brute Force Indicator)
       MITRE ATT&CK: T1110
       ════════════════════════════════════════════════════════════════════════ -->
  <rule id="100070" level="10" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <same_field>win.eventdata.targetUserName</same_field>
    <description>Multiple failed logon attempts for same user — possible brute force (T1110)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failure,brute_force,attack,</group>
  </rule>

</group>
